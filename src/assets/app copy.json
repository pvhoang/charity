                        {   "card": {
                                "items": [
                                    {	"text": {
                                            "label": "Hiệu trưởng, ban giám hiệu (qua giới thiệu từ đồng nghiệp, bạn hữu, người thân, v.v) liên lạc với hội tại Khánh Hòa.",
                                            "icon": { "zmdi": "run", "color": "success" }
                                        }
                                    },
                                    {	"text": {
                                            "label": "Sau đó BGH chuẩn bị danh sách 100 HS có hoàn cảnh khó khăn được nhận quà và 5 HS được nhận tiền mặt. Danh sách dạng Microsoft Excel gồm các thông tin: tên, giới tính, lớp, chiều cao, cân nặng. Xem mẫu đính kèm. Sau đó gởi về cho nhóm.",
                                            "icon": { "zmdi": "run", "color": "success" }
                                        }
                                    },
                                    {	"text": {
                                            "label": "Nhóm sẽ tổ chức chuyến đi tham quan trường để khảo sát và chia sẻ thêm thông tin với ban giám hiệu và các giáo viên. Trong buổi tham quan, nhóm và ban giám hiệu cùng nhau lên kế hoạch phát quà:",
                                            "icon": { "zmdi": "run", "color": "success" },
                                            "paras": [
                                                "• Chọn gói quà (1 hay 2), hoặc yêu cầu thay đổi để phù hợp với HS, v.v.",
                                                "• Chọn ngày phát quà"
                                            ]
                                        }
                                    },
                                    {	"text": {
                                            "label": "Đến ngày phát quà, nhóm sẽ đến trường phát quà tận tay HS (hoặc chuyển cho ban giám hiệu nếu điều kiện tập trung trong mùa dịch không thuận tiện). Dự kiến thời gian từ 9:00 - 11:00 sáng.",
                                            "icon": { "zmdi": "run", "color": "success" }
                                        }
                                    }
